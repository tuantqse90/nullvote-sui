VITE_SUI_NETWORK=testnet
VITE_SUI_RPC_URL=https://fullnode.testnet.sui.io:443
VITE_PACKAGE_ID=0x669ec8fee063206af29be9407865b5e2698f0f8f604b568c97c4e296acdb63be

# Local dev: point at the local uvicorn.
VITE_BACKEND_URL=http://localhost:8000

# Production deploy (Hostinger VPS) serves the frontend from the same origin
# as /api/*, so set this to the empty string for builds destined for
# https://nullvote.nullshift.sh — see infra/deploy/deploy.sh.
# VITE_BACKEND_URL=

# Circuit artifacts served from /public/circuit/:
#   vote.wasm         ~1.9 MB
#   vote_final.zkey   ~2.5 MB
#   verification_key.json
